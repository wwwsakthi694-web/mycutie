<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Annapoorani - Pink Blossoms</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pinyon+Script&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: radial-gradient(circle, #ffe3ec 0%, #ffb3c6 100%);
            font-family: "Pinyon Script", cursive;
        }

        /* Canvas for the falling blossoms */
        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* Container to center the text perfectly */
        .text-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 2;
            pointer-events: none;
        }

        /* Golden Shining Cursive Title with Fade & Zoom-in Animation */
        .name-title {
            font-size: 10vw; /* Responsive font size */
            font-weight: 400;
            white-space: nowrap;
            
            /* Luxurious Metallic Gold Gradient */
            background: linear-gradient(
                to bottom, 
                #fff3a1 0%, 
                #ffd700 40%, 
                #cca100 70%, 
                #ffae00 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            
            /* Realistic Golden Metallic Glow */
            filter: drop-shadow(0px 2px 5px rgba(0, 0, 0, 0.2))
                    drop-shadow(0px 0px 15px rgba(255, 215, 0, 0.6))
                    drop-shadow(0px 0px 30px rgba(255, 174, 0, 0.4));

            /* Triggering the intro animation */
            animation: introAnimation 4s ease-out forwards;
        }

        /* Keyframes for: Fade & Zoom in for 1s, then slightly fading out and staying there */
        @keyframes introAnimation {
            0% {
                transform: scale(0.3);
                opacity: 0;
                filter: drop-shadow(0px 0px 0px rgba(255, 215, 0, 0)) blur(5px);
            }
            25% { /* Around 1 second mark (25% of 4s) */
                transform: scale(1.1); /* Slight over-zoom for pop effect */
                opacity: 1;
                filter: drop-shadow(0px 2px 5px rgba(0, 0, 0, 0.2))
                        drop-shadow(0px 0px 25px rgba(255, 215, 0, 0.9));
            }
            35% {
                transform: scale(1); /* Settles to normal size */
                opacity: 1;
            }
            100% {
                transform: scale(1);
                opacity: 0.75; /* Fades slightly as requested and holds */
            }
        }
    </style>
</head>
<body>

    <canvas id="blossomsCanvas"></canvas>

    <div class="text-container">
        <h1 class="name-title">Annapoorani</h1>
    </div>

    <script>
        const canvas = document.getElementById('blossomsCanvas');
        const ctx = canvas.getContext('2d');

        // Set canvas to full screen
        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        // Blossom particle configuration
        const petalCount = 80;
        const petalsArray = [];

        class Petal {
            constructor() {
                this.x = Math.random() * canvas.width;
                // Start above screen or at random heights initially
                this.y = Math.random() * canvas.height - canvas.height;
                this.size = Math.random() * 12 + 8; // Size of blossom
                this.speedY = Math.random() * 1.5 + 1; // Downward speed
                this.speedX = Math.random() * 2 + 1.5; // Breeze horizontal movement
                this.angle = Math.random() * 360;
                this.spin = Math.random() * 2 - 1; // Rotation speed
                
                // Varied soft pink blossom shades
                const pinkShades = ['#ffb3c6', '#ff85a1', '#ffc2d1', '#ffe5ec', '#ff99b6'];
                this.color = pinkShades[Math.floor(Math.random() * pinkShades.length)];
                this.opacity = Math.random() * 0.4 + 0.6;
            }

            update() {
                this.y += this.speedY;
                this.x += this.speedX; // Falling in the direction of the breeze
                this.angle += this.spin;

                // Reset petal if it goes off screen (bottom or right side due to breeze)
                if (this.y > canvas.height || this.x > canvas.width) {
                    this.y = -20;
                    this.x = Math.random() * canvas.width - (canvas.width * 0.2); // Start further left to compensate for breeze
                    this.speedY = Math.random() * 1.5 + 1;
                    this.speedX = Math.random() * 2 + 1.5;
                }
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate((this.angle * Math.PI) / 180);
                ctx.globalAlpha = this.opacity;
                ctx.fillStyle = this.color;

                // Drawing a realistic organic cherry blossom petal shape
                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.bezierCurveTo(-this.size, -this.size / 2, -this.size, this.size, 0, this.size);
                ctx.bezierCurveTo(this.size, this.size, this.size, -this.size / 2, 0, 0);
                ctx.closePath();
                ctx.fill();

                // Center indentation line for depth
                ctx.beginPath();
                ctx.strokeStyle = 'rgba(255,255,255,0.4)';
                ctx.lineWidth = 1;
                ctx.moveTo(0, 0);
                ctx.lineTo(0, this.size * 0.7);
                ctx.stroke();

                ctx.restore();
            }
        }

        // Initialize petals
        function init() {
            for (let i = 0; i < petalCount; i++) {
                petalsArray.push(new Petal());
            }
        }

        // Animation loop
        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            for (let i = 0; i < petalsArray.length; i++) {
                petalsArray[i].update();
                petalsArray[i].draw();
            }
            
            requestAnimationFrame(animate);
        }

        init();
        animate();
    </script>
</body>
</html>
